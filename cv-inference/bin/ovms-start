#!/bin/bash
# OVMS startup wrapper for cv-inference snap daemon
# Reads the active engine binary path (set during install hook) and executes it.
# The engine-specific server script handles --file_system_poll_wait_seconds,
# --config_path, and --port configuration.
#
# Config reload: OVMS monitors $SNAP_COMMON/config/models_config.json
# and reloads models automatically every 5 seconds (--file_system_poll_wait_seconds 5).

set -e

ACTIVE_ENGINE_BINARY="$SNAP_COMMON/config/active_engine_binary"

if [ ! -f "$ACTIVE_ENGINE_BINARY" ]; then
    logger -p user.err -t cv-inference "No active engine binary configured. Run install hook first."
    exit 1
fi

ENGINE_BIN=$(cat "$ACTIVE_ENGINE_BINARY")

if [ ! -x "$ENGINE_BIN" ]; then
    logger -p user.err -t cv-inference "Engine binary not found or not executable: $ENGINE_BIN"
    exit 1
fi

logger -t cv-inference "Starting OVMS with engine: $ENGINE_BIN"
logger -t cv-inference "Config path: ${OVMS_CONFIG_PATH:-$SNAP_COMMON/config/models_config.json}"
logger -t cv-inference "gRPC port: ${OVMS_GRPC_PORT:-9000}"
logger -t cv-inference "File system poll: ${OVMS_FILE_SYSTEM_POLL_WAIT_SECONDS:-5}s"

exec "$ENGINE_BIN"
