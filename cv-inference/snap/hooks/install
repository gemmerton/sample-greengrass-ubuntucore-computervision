#!/bin/bash
# cv-inference snap install hook
# Auto-detects available hardware accelerators and selects the optimal engine.
# Implements `modelctl use-engine --auto` logic for hardware auto-detection.
# Priority: NPU > GPU > CPU (highest priority accelerator wins)
#
# If no supported Intel accelerator is detected, falls back to generic CPU
# engine and logs a warning.
#
# Requirements: 6.2, 6.7

set -e

CONFIG_DIR="$SNAP_COMMON/config"
MODELS_DIR="$SNAP_COMMON/models"
ENGINE_FILE="$SNAP_COMMON/config/active_engine"
ENGINES_DIR="$SNAP/etc/engines"

# Create persistent directories
mkdir -p "$CONFIG_DIR"
mkdir -p "$MODELS_DIR"

# Detect whether a specific hardware accelerator is present
detect_npu() {
    # Intel NPU exposed via /dev/accel/accel0 on supported kernels
    if [ -e /dev/accel/accel0 ]; then
        return 0
    fi
    # Fallback: check lspci for NPU/neural processing hardware
    if lspci 2>/dev/null | grep -qi "neural"; then
        return 0
    fi
    return 1
}

detect_gpu() {
    # Intel GPU render node
    if [ -e /dev/dri/renderD128 ]; then
        return 0
    fi
    # Fallback: check lspci for Intel Graphics
    if lspci 2>/dev/null | grep -qi "Intel.*Graphics"; then
        return 0
    fi
    return 1
}

detect_intel_cpu() {
    # Check /proc/cpuinfo for Intel vendor
    if grep -qi "GenuineIntel" /proc/cpuinfo 2>/dev/null; then
        return 0
    fi
    # Fallback: check lspci for Intel host bridge (indicates Intel platform)
    if lspci 2>/dev/null | grep -qi "Intel.*Host Bridge\|Intel.*Processor"; then
        return 0
    fi
    return 1
}

# Select engine based on priority: NPU > GPU > CPU
# This implements the logic behind `modelctl use-engine --auto`
select_engine() {
    local accelerator_found=false

    # Priority 3 (highest): Intel NPU
    if detect_npu; then
        accelerator_found=true
        echo "npu"
        return
    fi

    # Priority 2: Intel GPU
    if detect_gpu; then
        accelerator_found=true
        echo "gpu"
        return
    fi

    # Priority 1 (lowest): Intel CPU
    if detect_intel_cpu; then
        accelerator_found=true
        echo "cpu"
        return
    fi

    # No supported Intel accelerator detected - fallback to generic CPU
    # Requirement 6.7: activate generic CPU engine and log warning
    echo "cpu"
}

# Run engine selection (equivalent to `modelctl use-engine --auto`)
ENGINE=$(select_engine)

# Write active engine selection
echo "$ENGINE" > "$ENGINE_FILE"

# Log engine selection result
logger -t cv-inference "Hardware auto-detection complete (modelctl use-engine --auto). Selected engine: $ENGINE"

# Requirement 6.7: Log warning if no Intel accelerator was detected
if ! detect_npu && ! detect_gpu && ! detect_intel_cpu; then
    logger -p user.warning -t cv-inference \
        "WARNING: No supported Intel accelerator detected (checked NPU, GPU, CPU). Using generic CPU engine as fallback."
fi

# Activate the selected engine variant by recording which server binary to use
echo "$SNAP/usr/bin/ovms-${ENGINE}" > "$CONFIG_DIR/active_engine_binary"
logger -t cv-inference "Activated engine variant: $ENGINES_DIR/$ENGINE/engine.yaml"

# Initialize default OVMS configuration if not present
if [ ! -f "$CONFIG_DIR/models_config.json" ]; then
    cat > "$CONFIG_DIR/models_config.json" << 'EOF'
{
    "model_config_list": [
        {
            "config": {
                "name": "faster_rcnn",
                "base_path": "/snap/cv-inference/components/model-faster-rcnn"
            }
        }
    ]
}
EOF
    logger -t cv-inference "Initialized default OVMS configuration with faster_rcnn model"
fi
