#!/bin/bash
# cv-inference snap configure hook
# Handles snap configuration changes (engine override, port settings).
#
# Supported configuration keys:
#   engine: Override auto-detected engine (cpu, gpu, npu)
#   grpc-port: Override default gRPC port (default: 9000)

set -e

ENGINE_FILE="$SNAP_COMMON/config/active_engine"

# Handle engine override
ENGINE=$(snapctl get engine)
if [ -n "$ENGINE" ]; then
    case "$ENGINE" in
        cpu|gpu|npu)
            echo "$ENGINE" > "$ENGINE_FILE"
            logger -t cv-inference "Engine manually set to: $ENGINE"
            # Restart OVMS to use new engine
            snapctl restart cv-inference.ovms
            ;;
        auto)
            # Re-run auto-detection
            "$SNAP/snap/hooks/install"
            snapctl restart cv-inference.ovms
            ;;
        *)
            echo "Invalid engine value: $ENGINE. Must be one of: cpu, gpu, npu, auto" >&2
            exit 1
            ;;
    esac
fi

# Handle gRPC port override
PORT=$(snapctl get grpc-port)
if [ -n "$PORT" ]; then
    if [ "$PORT" -ge 1024 ] && [ "$PORT" -le 65535 ] 2>/dev/null; then
        logger -t cv-inference "gRPC port set to: $PORT"
        snapctl restart cv-inference.ovms
    else
        echo "Invalid port: $PORT. Must be between 1024 and 65535" >&2
        exit 1
    fi
fi
