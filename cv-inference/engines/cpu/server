#!/bin/bash
# OVMS startup script for CPU engine variant
# Launches OpenVINO Model Server with CPU-optimised configuration
#
# Configuration:
#   --config_path: Multi-model config from $SNAP_COMMON/config/models_config.json
#   --port: gRPC endpoint (default 9000, TensorFlow Serving Predict API)
#   --file_system_poll_wait_seconds: Config reload interval (5 seconds)

set -e

CONFIG_PATH="${OVMS_CONFIG_PATH:-$SNAP_COMMON/config/models_config.json}"
GRPC_PORT="${OVMS_GRPC_PORT:-9000}"
POLL_SECONDS="${OVMS_FILE_SYSTEM_POLL_WAIT_SECONDS:-5}"

exec ovms \
    --config_path "$CONFIG_PATH" \
    --port "$GRPC_PORT" \
    --file_system_poll_wait_seconds "$POLL_SECONDS" \
    --target_device CPU \
    --cpu_extension "" \
    --log_level INFO
